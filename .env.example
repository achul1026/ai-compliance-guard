# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_db
DB_USER=postgres
DB_PASSWORD=postgres

# P1-5: Upstage Embedding (Solar-embedding-1-large)
UPSTAGE_API_KEY=your_upstage_api_key_here
UPSTAGE_EMBEDDING_MODEL=solar-embedding-1-large
UPSTAGE_API_URL=https://api.upstage.ai/v1/embeddings
UPSTAGE_EMBEDDING_DIMENSION=4096
UPSTAGE_TIMEOUT_SECONDS=30
UPSTAGE_BATCH_SIZE=20
UPSTAGE_MAX_RETRIES=3

# LLM (Phase 2 이후)
LLM_PROVIDER=openai
LLM_API_KEY=

# Spring 프로파일 (local | prod)
SPRING_PROFILES_ACTIVE=local
